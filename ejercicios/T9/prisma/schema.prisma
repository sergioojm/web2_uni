generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  LIBRARIAN
  ADMIN
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  loans     Loan[]
  reviews   Review[]
}

model Book {
  id            String   @id @default(cuid())
  isbn          String   @unique
  title         String
  author        String
  genre         String
  description   String?
  publishedYear Int
  copies        Int
  available     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  loans         Loan[]
  reviews       Review[]
}

model Loan {
  id         String     @id @default(cuid())
  userId     String
  bookId     String
  loanDate   DateTime   @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     LoanStatus @default(ACTIVE)
  user       User       @relation(fields: [userId], references: [id])
  book       Book       @relation(fields: [bookId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  book      Book     @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
}
